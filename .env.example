# ============================================================
#  AgriGenie AI – Smart Farming Advice Agent
#  Environment Configuration Template
#  Copy this file to .env and fill in your values
# ============================================================

# IBM watsonx.ai Credentials (REQUIRED)
IBM_API_KEY=your_ibm_api_key_here
IBM_PROJECT_ID=your_watsonx_project_id_here
IBM_URL=https://us-south.ml.cloud.ibm.com
IBM_MODEL_ID=ibm/granite-3-2-8b-instruct

# Flask Configuration
FLASK_SECRET_KEY=change-this-to-a-random-secret-key
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_PORT=5000

# Database
DATABASE_URL=sqlite:///instance/agrigenie.db

# RAG / Vector Store Configuration
VECTOR_STORE=faiss
KNOWLEDGE_BASE_DIR=knowledge_base
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RESULTS=5

# Weather API (optional – uses mock data if blank)
OPENWEATHER_API_KEY=
DEFAULT_LOCATION=New Delhi, IN

# Report Generation
REPORTS_DIR=reports
MAX_REPORT_AGE_DAYS=30
